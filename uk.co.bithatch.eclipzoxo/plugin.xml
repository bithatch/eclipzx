           <separator name="uk.co.bithatch.eclipzoxo.menus.sep" visible="true"/>
                 
           <command
                 commandId="uk.co.bithatch.eclipzoxo.commands.nmi"
                 icon="icons/nmi16.png" 
                 label="Generate NMI"
                 tooltip="Geneate a non-maskable interupt"
                 style="push"/>
                 
           <command
                 commandId="uk.co.bithatch.eclipzoxo.commands.poke"
                 icon="icons/poke16.png" 
                 label="Poke Address"
                 tooltip="Poke an address with a value"
                 style="push"/>
        
           <command
                 commandId="uk.co.bithatch.eclipzoxo.commands.screenshot"
                 label="Screenshot"
                 icon="icons/screenshot16.png" 
                 tooltip="Take a screenshot"
                 style="push"/>
                 
        </menuContribution>

    
      <menuContribution
            locationURI="menu:uk.co.bithatch.eclipzoxo.editor.menus.tape">
            
          <command
                commandId="uk.co.bithatch.eclipzoxo.commands.record"
                icon="icons/record16.png"
                label="Record To Tape"
