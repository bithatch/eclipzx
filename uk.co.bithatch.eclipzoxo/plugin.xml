<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="4.35"?>
<plugin>

    <extension-point id="uk.co.bithatch.eclipzoxo.addOn" name="Zoxo Add-on Implementation" schema="schema/uk.co.bithatch.eclipzoxo.addOn.exsd" />
    <extension-point id="uk.co.bithatch.eclipzoxo.machine" name="Zoxo Machine Implementation" schema="schema/uk.co.bithatch.eclipzoxo.machine.exsd" />

    <extension point="uk.co.bithatch.eclipzoxo.machine">
        <machine class="uk.co.bithatch.zoxo.zxspectrum.ZXSpectrum16K$ZXSpectrum16KFactory"/>
        <machine class="uk.co.bithatch.zoxo.zxspectrum.ZXSpectrum48K$ZXSpectrum48KFactory"/>
        <machine class="uk.co.bithatch.zoxo.zxspectrum.ZXSpectrum128K$ZXSpectrum128KFactory"/>
        <machine class="uk.co.bithatch.zoxo.zxspectrum.ZXSpectrumPlus2$ZXSpectrumPlus2Factory"/>
        <machine class="uk.co.bithatch.zoxo.zxspectrum.ZXSpectrumPlus2A$ZXSpectrumPlus2AFactory"/>
        <machine class="uk.co.bithatch.zoxo.zxspectrum.ZXSpectrumPlus3$ZXSpectrumPlus3Factory"/>
    </extension>
    
    <extension point="uk.co.bithatch.eclipzoxo.addOn">
        <addOn class="uk.co.bithatch.zoxo.tape.DefaultTapePlayerAddOn$DefaultTapeAddOnFactory"/>
        <addOn class="uk.co.bithatch.zoxo.interface1.Interface1AddOn$Interface1AddOnFactory"/>
        <addOn class="uk.co.bithatch.zoxo.interface2.Interface2AddOn$Interface2AddOnFactory"/>
        <addOn class="uk.co.bithatch.zoxo.zxkeyboard.ZXKeyboardAddOn$ZXKeyboardAddOnFactory"/>
        <addOn class="uk.co.bithatch.zoxo.dezog.DeZogAddOn$DeZOGAddOnFactory"/>
        <addOn class="uk.co.bithatch.zoxo.snapshots.SnapshotsAddOn$SnapshotsAddOnFactory"/>
        <addOn class="uk.co.bithatch.zoxo.audio.BeeperAddOn$BeeperAddOnFactory"/>
        <addOn class="uk.co.bithatch.zoxo.ay8912.AY8912AddOn$AY8912AddOnFactory"/>
        
    </extension>
    
    <extension point="org.eclipse.ui.editors">
        <editor
            id="uk.co.bithatch.eclipzoxo.editor.TapeBrowser"
            name="Tape Browser"
            class="uk.co.bithatch.eclipzoxo.editor.TapeBrowser"
            icon="icons/tape16.png"
            contributorClass="org.eclipse.ui.part.EditorActionBarContributor">
            <contentTypeBinding contentTypeId="uk.co.bithatch.eclipzoxo.tzx.contenttype"/>
            <contentTypeBinding contentTypeId="uk.co.bithatch.eclipzoxo.tap.contenttype"/>
            <contentTypeBinding contentTypeId="uk.co.bithatch.eclipzoxo.csw.contenttype"/>
        </editor>
    </extension>

    <extension point="org.eclipse.ui.views">
        <category id="uk.co.bithatch.eclipzoxo.category"
                name="ZX Spectrum Emulator"/>
        <view category="uk.co.bithatch.eclipzoxo.category" 
              class="uk.co.bithatch.eclipzoxo.views.KeyboardView" 
              icon="icons/keys16.png" 
              id="uk.co.bithatch.eclipzoxo.views.KeyboardView" 
              inject="true"
              name="ZX Spectrum 16K/48K Keyboard" >
        </view>
        <view
            id="uk.co.bithatch.eclipzoxo.views.EmulatorView"
            name="ZX Spectrum Emulator"
            class="uk.co.bithatch.eclipzoxo.views.EmulatorView"
            category="uk.co.bithatch.eclipzoxo.category"
            icon="icons/zoxo16.png">
        </view>
    </extension>
    <extension point="org.eclipse.core.contenttype.contentTypes">
        <content-type
            file-extensions="z80"
            id="uk.co.bithatch.eclipzoxo.z80.contenttype"
            name="Z80 Spectrum Snapshot"
            priority="normal">
        </content-type>
        <content-type
            file-extensions="sna"
            id="uk.co.bithatch.eclipzoxo.sna.contenttype"
            name="SNA Spectrum Snapshot"
            priority="normal">
        </content-type>
        <content-type
            file-extensions="szx"
            id="uk.co.bithatch.eclipzoxo.szx.contenttype"
            name="SZX Spectrum Snapshot"
            priority="normal">
        </content-type>
        <content-type
            file-extensions="sp"
            id="uk.co.bithatch.eclipzoxo.sp.contenttype"
            name="SP Spectrum Snapshot"
            priority="normal">
        </content-type>
        <content-type
            file-extensions="tap"
            id="uk.co.bithatch.eclipzoxo.tap.contenttype"
            name="TAP Tape Container"
            priority="normal">
        </content-type>
        <content-type
            file-extensions="tzx"
            id="uk.co.bithatch.eclipzoxo.tzx.contenttype"
            name="TZX Tape Container"
            priority="normal">
        </content-type>
        <content-type
            file-extensions="cws"
            id="uk.co.bithatch.eclipzoxo.csw.contenttype"
            name="CSW Tape Container"
            priority="normal">
        </content-type>
        <content-type
            file-extensions="rom"
            id="uk.co.bithatch.eclipzoxo.rom.contenttype"
            name="Spectrum Rom"
            priority="normal">
        </content-type>
        <content-type
            file-extensions="mdv"
            id="uk.co.bithatch.eclipzoxo.mdv.contenttype"
            name="Spectrum Microdrive Cartridge"
            priority="normal">
        </content-type>
        <content-type
            file-extensions="mdr"
            id="uk.co.bithatch.eclipzoxo.mdr.contenttype"
            name="Spectrum Microdrive Cartridge"
            priority="normal">
        </content-type>
        <content-type
            file-extensions="bin"
            id="uk.co.bithatch.eclipzoxo.bin.contenttype"
            name="Spectrum Binary Data"
            priority="low">
        </content-type>
    </extension>
    
    <extension
            point="org.eclipse.ui.preferencePages">
 
          <page
                id="uk.co.bithatch.eclipzoxo.preferences.zoxo"
                name="Zoxo"
                class="uk.co.bithatch.eclipzoxo.preferences.ZoxoPreferencePage" />

          <page
                id="uk.co.bithatch.eclipzoxo.preferences.addOns"
                name="Add-Ons"
                category="uk.co.bithatch.eclipzoxo.preferences.zoxo"
                class="uk.co.bithatch.eclipzoxo.preferences.AddOnsPreferencePage" />

          <page
                id="uk.co.bithatch.eclipzoxo.preferences.interface1"
                name="Interface 1"
                category="uk.co.bithatch.eclipzoxo.preferences.zoxo"
                class="uk.co.bithatch.eclipzoxo.preferences.Interface1PreferencePage" />
        
          <page
                id="uk.co.bithatch.eclipzoxo.preferences.interface2"
                name="Interface 2"
                category="uk.co.bithatch.eclipzoxo.preferences.zoxo"
                class="uk.co.bithatch.eclipzoxo.preferences.Interface2PreferencePage" />
        
          <page
                id="uk.co.bithatch.eclipzoxo.preferences.audio"
                name="Audio"
                category="uk.co.bithatch.eclipzoxo.preferences.zoxo"
                class="uk.co.bithatch.eclipzoxo.views.AudioPreferencePage" />
        
          <page
                id="uk.co.bithatch.eclipzoxo.preferences.tape"
                name="Tape"
                category="uk.co.bithatch.eclipzoxo.preferences.zoxo"
                class="uk.co.bithatch.eclipzoxo.preferences.TapePreferencePage" />
                
                
          <page
                id="uk.co.bithatch.eclipzoxo.preferences.dezog"
                name="Debugger"
                category="uk.co.bithatch.eclipzoxo.preferences.zoxo"
                class="uk.co.bithatch.eclipzoxo.preferences.DeZogPreferencePage" />
    </extension>
    

    <extension point="org.eclipse.ui.commands">
        <category
            id="uk.co.bithatch.eclipzoxo.commands.category"
            name="Zoxo Commands" />
    
        <command
            id="uk.co.bithatch.eclipzoxo.commands.record"
            name="Record To Tape"
            categoryId="uk.co.bithatch.eclipzoxo.commands.category" />
    
        <command
            id="uk.co.bithatch.eclipzoxo.commands.stop"
            name="Stop Tape"
            categoryId="uk.co.bithatch.eclipzoxo.commands.category" />
    
        <command
            id="uk.co.bithatch.eclipzoxo.commands.rewind"
            name="Rewind Tape"
            categoryId="uk.co.bithatch.eclipzoxo.commands.category" />
    
        <command
            id="uk.co.bithatch.eclipzoxo.commands.play"
            name="Play Tape"
            categoryId="uk.co.bithatch.eclipzoxo.commands.category" />
        
        <command
            id="uk.co.bithatch.eclipzoxo.commands.openInTapeBrowser"
            name="Open in Tape Browser"
            description="Open selected file in the Tape Browser">
        </command>
        
        <command
            id="uk.co.bithatch.eclipzoxo.commands.openInEmulator"
            name="Open in Zoxo Emulator"
            description="Open selected file in the Zoxo Emulator">
        </command>
        
        <command
            id="uk.co.bithatch.eclipzoxo.commands.insertROMFromFileSystem"
            name="Insert ROM from Filesystem"
            description="Locate, insert and start a .rom file from the local file system">
        </command>
        
        <command
            id="uk.co.bithatch.eclipzoxo.commands.insertTapeFromFileSystem"
            name="Insert Tape from Filesystem"
            description="Locate, insert and start a .tzx,.tap or .csv file from the local file system">
        </command>
        
        <command
            id="uk.co.bithatch.eclipzoxo.commands.ejectROM"
            name="Eject ROM and Reset"
            description="Eject the current ROM and reset the emulator">
        </command>
        
        <command
            id="uk.co.bithatch.eclipzoxo.commands.screenshot"
            name="Screenshot"
            description="Take a screenshot">
        </command>
        
        <command
            id="uk.co.bithatch.eclipzoxo.commands.microdrives"
            name="Microdrives"
            description="Manage Microdrives">
        </command>
        
        <command
            id="uk.co.bithatch.eclipzoxo.commands.nmi"
            name="Generate NMI"
            description="Generate NMI">
        </command>
        
        <command
            id="uk.co.bithatch.eclipzoxo.commands.poke"
            name="Poke Address"
            description="Poke an address with a value">
        </command>
        
        <command
            id="uk.co.bithatch.eclipzoxo.commands.ejectTape"
            name="Eject Tape"
            description="Eject the current tape">
        </command>
    </extension>
    
    <extension point="org.eclipse.ui.handlers">
        <handler
            commandId="uk.co.bithatch.eclipzoxo.commands.record"
            class="uk.co.bithatch.eclipzoxo.commands.RecordHandler">
            
             <enabledWhen>
                <or>
                   <with variable="activeEditor">
                      <instanceof value="uk.co.bithatch.eclipzoxo.editor.TapeBrowser"/>
                      <and>
                          <test property="uk.co.bithatch.eclipzoxo.editor.inserted" value="true"/>
                          <test property="uk.co.bithatch.eclipzoxo.editor.running" value="false"/>
                          <test property="uk.co.bithatch.eclipzoxo.editor.recording" value="false"/>
                      </and>
                    </with>
                    <with variable="activePart">
                        <instanceof value="uk.co.bithatch.eclipzoxo.views.EmulatorView"/>
                        <and>
                            <test property="uk.co.bithatch.eclipzoxo.views.tapeInserted" value="true"/>
                            <test property="uk.co.bithatch.eclipzoxo.views.tapeRunning" value="false"/>
                            <test property="uk.co.bithatch.eclipzoxo.views.tapeRecording" value="false"/>
                        </and>
                    </with>
                </or>
            </enabledWhen>
            
        </handler>
        <handler
            commandId="uk.co.bithatch.eclipzoxo.commands.stop"
            class="uk.co.bithatch.eclipzoxo.commands.StopHandler">
            
            <enabledWhen>
                <or>
                   <with variable="activeEditor">
                      <instanceof value="uk.co.bithatch.eclipzoxo.editor.TapeBrowser"/>
                      <test property="uk.co.bithatch.eclipzoxo.editor.running" value="true"/>
                    </with>
                    <with variable="activePart">
                        <instanceof value="uk.co.bithatch.eclipzoxo.views.EmulatorView"/>
                        <test property="uk.co.bithatch.eclipzoxo.views.tapeRunning" value="true"/>
                    </with>
                </or>
            </enabledWhen>
            
        </handler>
        <handler
            commandId="uk.co.bithatch.eclipzoxo.commands.rewind"
            class="uk.co.bithatch.eclipzoxo.commands.RewindHandler">
            
             <enabledWhen>
                <or>
                   <with variable="activeEditor">
                      <instanceof value="uk.co.bithatch.eclipzoxo.editor.TapeBrowser"/>
                      <test property="uk.co.bithatch.eclipzoxo.editor.inserted" value="true"/>
                    </with>
                    <with variable="activePart">
                        <instanceof value="uk.co.bithatch.eclipzoxo.views.EmulatorView"/>
                        <test property="uk.co.bithatch.eclipzoxo.views.tapeInserted" value="true"/>
                    </with>
                </or>
            </enabledWhen>
        </handler>
        <handler
            commandId="uk.co.bithatch.eclipzoxo.commands.play"
            class="uk.co.bithatch.eclipzoxo.commands.PlayHandler">
            
            <enabledWhen>
                <or>
                   <with variable="activeEditor">
                      <instanceof value="uk.co.bithatch.eclipzoxo.editor.TapeBrowser"/>
                      <and>
                          <test property="uk.co.bithatch.eclipzoxo.editor.inserted" value="true"/>
                          <test property="uk.co.bithatch.eclipzoxo.editor.running" value="false"/>
                      </and>
                    </with>
                    <with variable="activePart">
                        <instanceof value="uk.co.bithatch.eclipzoxo.views.EmulatorView"/>
                        <and>
                            <test property="uk.co.bithatch.eclipzoxo.views.tapeInserted" value="true"/>
                            <test property="uk.co.bithatch.eclipzoxo.views.tapeRunning" value="false"/>
                        </and>
                    </with>
                </or>
            </enabledWhen>
            
        </handler>
        <handler
            commandId="uk.co.bithatch.eclipzoxo.commands.ejectTape"
            class="uk.co.bithatch.eclipzoxo.commands.EjectTapeHandler">
              <enabledWhen>
                <or>
                   <with variable="activeEditor">
                      <instanceof value="uk.co.bithatch.eclipzoxo.editor.TapeBrowser"/>
                      <and>
                          <test property="uk.co.bithatch.eclipzoxo.editor.inserted" value="true"/>
                          <test property="uk.co.bithatch.eclipzoxo.editor.running" value="false"/>
                      </and>
                    </with>
                    <with variable="activePart">
                        <instanceof value="uk.co.bithatch.eclipzoxo.views.EmulatorView"/>
                      <and>
                        <test property="uk.co.bithatch.eclipzoxo.views.tapeInserted" value="true"/>
                        <test property="uk.co.bithatch.eclipzoxo.views.tapeRunning" value="false"/>
                        </and>
                    </with>
                </or>
            </enabledWhen>
        </handler>
        <handler
            commandId="uk.co.bithatch.eclipzoxo.commands.openInEmulator"
            class="uk.co.bithatch.eclipzoxo.commands.OpenInEmulatorHandler">
        </handler>
        <handler
            commandId="uk.co.bithatch.eclipzoxo.commands.openInTapeBrowser"
            class="uk.co.bithatch.eclipzoxo.commands.OpenInTapeBrowserHandler">
        </handler>
        <handler
            commandId="uk.co.bithatch.eclipzoxo.commands.insertROMFromFileSystem"
            class="uk.co.bithatch.eclipzoxo.commands.InsertROMFromFileSystemHandler">
            
            <enabledWhen>
              <with variable="activePart">
                <instanceof value="uk.co.bithatch.eclipzoxo.views.EmulatorView"/>
                 <not>
                   <test property="uk.co.bithatch.eclipzoxo.views.activeMedia" value="rom"/>
                 </not>
              </with>
            </enabledWhen>
            
        </handler>
        
        <handler
            commandId="uk.co.bithatch.eclipzoxo.commands.insertTapeFromFileSystem"
            class="uk.co.bithatch.eclipzoxo.commands.InsertTapeFromFileSystemHandler">
            
            <enabledWhen>
              <with variable="activePart">
                <instanceof value="uk.co.bithatch.eclipzoxo.views.EmulatorView"/>
                 <not>
                   <test property="uk.co.bithatch.eclipzoxo.views.activeMedia" value="tape"/>
                 </not>
              </with>
            </enabledWhen>
            
        </handler>
        <handler
            commandId="uk.co.bithatch.eclipzoxo.commands.ejectROM"
            class="uk.co.bithatch.eclipzoxo.commands.EjectROMHandler">
            <enabledWhen>
              <with variable="activePart">
                <instanceof value="uk.co.bithatch.eclipzoxo.views.EmulatorView"/>
              <test property="uk.co.bithatch.eclipzoxo.views.activeMedia" value="rom"/>
              </with>
            </enabledWhen>
        </handler>
        
        <handler
            commandId="uk.co.bithatch.eclipzoxo.commands.microdrives"
            class="uk.co.bithatch.eclipzoxo.commands.MicrodrivesHandler">
            <enabledWhen>
              <with variable="activePart">
                <instanceof value="uk.co.bithatch.eclipzoxo.views.EmulatorView"/>
                <test property="uk.co.bithatch.eclipzoxo.views.microdrives" value="true"/>
              </with>
            </enabledWhen>
        </handler>
        
        <handler
            commandId="uk.co.bithatch.eclipzoxo.commands.nmi"
            class="uk.co.bithatch.eclipzoxo.commands.NMIHandler">
            <enabledWhen>
              <with variable="activePart">
                <instanceof value="uk.co.bithatch.eclipzoxo.views.EmulatorView"/>
              </with>
            </enabledWhen>
        </handler>
        
        <handler
            commandId="uk.co.bithatch.eclipzoxo.commands.poke"
            class="uk.co.bithatch.eclipzoxo.commands.PokeHandler">
            <enabledWhen>
              <with variable="activePart">
                <instanceof value="uk.co.bithatch.eclipzoxo.views.EmulatorView"/>
              </with>
            </enabledWhen>
        </handler>
        
        <handler
            commandId="uk.co.bithatch.eclipzoxo.commands.screenshot"
            class="uk.co.bithatch.eclipzoxo.commands.ScreenshotHandler">
            <enabledWhen>
              <with variable="activePart">
                <instanceof value="uk.co.bithatch.eclipzoxo.views.EmulatorView"/>
              </with>
            </enabledWhen>
        </handler>
    </extension>
    
    <extension point="org.eclipse.ui.menus">
    
        <menuContribution locationURI="menu:org.eclipse.ui.main.menu?after=navigate">
            <menu
                id="uk.co.bithatch.eclipzoxo.editor.menus.tape"
                label="Tape">
                <visibleWhen>
                    <with variable="activeEditorId">
                        <or>
                            <equals value="uk.co.bithatch.eclipzoxo.editor.TapeBrowser"/>
                        </or>
                    </with>
                </visibleWhen>
            </menu>
            
             <menu
                id="uk.co.bithatch.eclipzoxo.views.menus.emulator"
                label="Emulator">
                <visibleWhen>
                    <with variable="activePart">
                        <instanceof value="uk.co.bithatch.eclipzoxo.views.EmulatorView"/>
                        <!--<test property="org.example.myViewPart.inputType" value="type1"/>-->
                    </with>
                </visibleWhen>
            </menu>
        </menuContribution>
    
