<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.0"?>
<plugin>
	<extension
		point="org.eclipse.ui.editors">
		<editor
        class="uk.co.bithatch.eclipz80.ui.AsmExecutableExtensionFactory:org.eclipse.xtext.ui.editor.XtextEditor"
        contributorClass="org.eclipse.ui.editors.text.TextEditorActionContributor"
        default="true"
        extensions="asm"
        icon="icons/asm16.png"
        id="uk.co.bithatch.eclipz80.Asm"
        name="Asm Editor">
		</editor>
	</extension>
	
	<extension
		point="org.eclipse.ui.handlers">
		
        <handler commandId="uk.co.bithatch.eclipz80.ui.debug.toggleBreakpoint" class="uk.co.bithatch.eclipz80.ui.AsmExecutableExtensionFactory:uk.co.bithatch.eclipz80.ui.debug.ToggleBreakpointHandler">
            <activeWhen>
                <reference definitionId="uk.co.bithatch.eclipz80.Asm.Editor.opened" />
            </activeWhen>
        </handler>
		<handler
			class="uk.co.bithatch.eclipz80.ui.AsmExecutableExtensionFactory:org.eclipse.xtext.ui.editor.hyperlinking.OpenDeclarationHandler"
			commandId="org.eclipse.xtext.ui.editor.hyperlinking.OpenDeclaration">
			<activeWhen>
				<reference
					definitionId="uk.co.bithatch.eclipz80.Asm.Editor.opened">
				</reference>
			</activeWhen>
		</handler>
		<handler
			class="uk.co.bithatch.eclipz80.ui.AsmExecutableExtensionFactory:org.eclipse.xtext.ui.editor.handler.ValidateActionHandler"
			commandId="uk.co.bithatch.eclipz80.Asm.validate">
			<activeWhen>
				<reference
					definitionId="uk.co.bithatch.eclipz80.Asm.Editor.opened">
				</reference>
			</activeWhen>
		</handler>
		<!-- copy qualified name -->
		<handler
			class="uk.co.bithatch.eclipz80.ui.AsmExecutableExtensionFactory:org.eclipse.xtext.ui.editor.copyqualifiedname.EditorCopyQualifiedNameHandler"
			commandId="org.eclipse.xtext.ui.editor.copyqualifiedname.EditorCopyQualifiedName">
			<activeWhen>
				<reference definitionId="uk.co.bithatch.eclipz80.Asm.Editor.opened" />
			</activeWhen>
		</handler>
		<handler
			class="uk.co.bithatch.eclipz80.ui.AsmExecutableExtensionFactory:org.eclipse.xtext.ui.editor.copyqualifiedname.OutlineCopyQualifiedNameHandler"
			commandId="org.eclipse.xtext.ui.editor.copyqualifiedname.OutlineCopyQualifiedName">
			<activeWhen>
				<and>
					<reference definitionId="uk.co.bithatch.eclipz80.Asm.XtextEditor.opened" />
					<iterate>
						<adapt type="org.eclipse.xtext.ui.editor.outline.IOutlineNode" />
					</iterate>
				</and>
			</activeWhen>
		</handler>
	</extension>
	<extension point="org.eclipse.core.expressions.definitions">
		<definition id="uk.co.bithatch.eclipz80.Asm.Editor.opened">
			<and>
				<reference definitionId="isActiveEditorAnInstanceOfXtextEditor"/>
				<with variable="activeEditor">
					<test property="org.eclipse.xtext.ui.editor.XtextEditor.languageName"
						value="uk.co.bithatch.eclipz80.Asm"
						forcePluginActivation="true"/>
				</with>
			</and>
		</definition>
		<definition id="uk.co.bithatch.eclipz80.Asm.XtextEditor.opened">
			<and>
				<reference definitionId="isXtextEditorActive"/>
				<with variable="activeEditor">
					<test property="org.eclipse.xtext.ui.editor.XtextEditor.languageName"
						value="uk.co.bithatch.eclipz80.Asm"
						forcePluginActivation="true"/>
				</with>
			</and>
		</definition>
	</extension>
