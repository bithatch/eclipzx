			class="uk.co.bithatch.eclipz80.ui.wizard.AsmProjectWizard"
			category="uk.co.bithatch.eclipzx.projects.category"
			icon="icons/asm16.png"
			project="true">
			<description>Create a new Z80 assembly project with .asm file support</description>
		</wizard>
	</extension>
	
